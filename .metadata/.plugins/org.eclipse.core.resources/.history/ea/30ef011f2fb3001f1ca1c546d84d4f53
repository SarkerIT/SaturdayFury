package com.upskill.java_4;


// Step 1: Make a Person Class
class Person {
	String name; // Instance variable
	int age; // Instance variable
	
	 public Person() {
		 this.name = "John";
		 this.age = 45;
	 }

	// Inside the class make a Constructor with parameters
	public Person(String name, int age) {   // this constructor will take two parameters
		this.name = name; // "this.name" refers to the instance variable
		this.age = age; // "this.age" refers to the instance variable
	}

	// Inside the class make a Method to display the person details
	public void display() {
		System.out.println("Name: " + name + ", Age: " + age);
	}
}

public class Constructor_Example {
	public static void main(String[] args) {
		// Creating a Person object
		Person person = new Person("Alice", 30);

		// Calling the display method
		person.display(); // Output: Name: Alice, Age: 30
		
		
		Person person2 = new Person();
		person2.display(); 
	}
}
